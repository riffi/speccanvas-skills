{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Data Specification v1.0",
  "type": "object",
  "required": ["format_version", "metadata", "entities"],
  "additionalProperties": false,
  "properties": {
    "docType": {
      "type": "string",
      "enum": ["data-spec"],
      "description": "Тип документа"
    },
    "format_version": {
      "type": "string",
      "description": "Версия формата спецификации (например: 0.0.1)",
      "minLength": 1,
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "version": {"type": "string"},
        "author": {"type": "string"},
        "description_short": {"type": "string"},
        "created_at": {"type": "string"},
        "updated_at": {"type": "string"}
      }
    },
    "description": {"type": "string"},
    "enums": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "values": {
                "type": "array",
                "items": {"type": "string"}
              },
              "description": {"type": "string"}
            },
            "required": ["values"]
          },
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "description": {"type": "string"},
              "values": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name"],
                  "properties": {
                    "name": {"type": "string"},
                    "label": {"type": "string"},
                    "description": {"type": "string"}
                  }
                }
              }
            },
            "required": ["values"]
          }
        ]
      }
    },
    "entities": {
      "type": "object",
      "patternProperties": {
        "^[a-z_][a-z0-9_]*$": {
          "type": "object",
          "required": ["fields"],
          "additionalProperties": false,
          "properties": {
            "label": {"type": "string"},
            "description": {"type": "string"},
            "table_name": {"type": "string"},
            "fields": {
              "type": "object",
              "patternProperties": {
                "^[a-z_][a-z0-9_]*$": {
                  "$ref": "#/definitions/field"
                }
              },
              "additionalProperties": false
            },
            "unique_constraints": {
              "type": "array",
              "items": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string"}
              }
            }
          }
        }
      },
      "additionalProperties": false
    },
    "relations": {
      "type": "array",
      "items": { "$ref": "#/definitions/relation" }
    },
    "diagram": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": {"enum": ["mermaid"]},
        "hints": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "nodes": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "x": {"type": "number"},
                  "y": {"type": "number"},
                  "group": {"type": "string"},
                  "color": {"type": "string"}
                }
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "builtInTypes": {
      "enum": [
        "string",
        "integer",
        "decimal",
        "boolean",
        "datetime",
        "uuid",
        "json"
      ]
    },
    "scalarOrArray": {
      "oneOf": [
        {"type": "string"},
        {"type": "number"},
        {"type": "boolean"},
        {"type": "null"},
        {"type": "object"},
        {"type": "array"}
      ]
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {"type": "string"},
        "label": {"type": "string"},
        "description": {"type": "string"},
        "required": {"type": "boolean"},
        "pk": {"type": "boolean"},
        "unique": {"type": "boolean"},
        "default": {"$ref": "#/definitions/scalarOrArray"},
        "fk": {"type": "string", "pattern": "^[a-z_][a-z0-9_]*\\.[a-z_][a-z0-9_]*$"}
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_a", "entity_b", "cardinality"],
      "properties": {
        "entity_a": {"type": "string", "pattern": "^[a-z_][a-z0-9_]*$"},
        "entity_b": {"type": "string", "pattern": "^[a-z_][a-z0-9_]*$"},
        "cardinality": {"enum": ["one_to_one", "one_to_many", "many_to_many"]},
        "description": {"type": "string"},
        "label": {"type": "string"}
      }
    }
  }
}
